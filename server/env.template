# DevDecks Server Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# MongoDB Connection String
# For local development:
MONGO_URI=mongodb://localhost:27017/flashcard-app

# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/devdecks?retryWrites=true&w=majority

# ===========================================
# AUTHENTICATION
# ===========================================

# JWT Secret Key (minimum 32 characters, use a random string)
# Generate one at: https://randomkeygen.com/
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server Port (default: 5001)
PORT=5001

# Node Environment (development | production)
NODE_ENV=development

# Frontend URL (for CORS configuration)
# Development:
FRONTEND_URL=http://localhost:3000
# Production (update with your Vercel URL):
# FRONTEND_URL=https://your-app.vercel.app

# Gemini API Key
GEMINI_API_KEY = your-gemini-api-key

# ===========================================
# EXTERNAL APIS (Optional)
# ===========================================

# Merriam-Webster Dictionary API Key
# Get one at: https://dictionaryapi.com/
DICTIONARY_API_KEY=your-dictionary-api-key

# YouTube Data API Key
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key

# ===========================================
# EMBEDDINGS & VECTOR SEARCH (Module A)
# ===========================================

# Provider for text-to-vector. 'gemini' uses Google's gemini-embedding-001 (free
# tier; reuses GEMINI_API_KEY above). 'hash' is a deterministic local fallback
# used by tests and when GEMINI_API_KEY is unset.
EMBEDDING_PROVIDER=gemini

# Embedding model name passed to Gemini. gemini-embedding-001 is the supported
# default; it produces 3072-dim vectors but accepts outputDimensionality to
# truncate to 768/1536. Must match the numDimensions of any Atlas Vector Search
# indexes you've built (see server/docs/atlas-vector-index.md).
EMBEDDING_MODEL=gemini-embedding-001

# Output dimension passed as outputDimensionality. 768 is the recommended
# minimum that retains quality while keeping Mongo doc size reasonable.
EMBEDDING_DIMENSION=768

# Vector store backend used by hybridSearch.
#   brute = in-process cosine over Mongo documents (works everywhere; default).
#   atlas = MongoDB Atlas $vectorSearch (requires the indexes documented in
#           server/docs/atlas-vector-index.md to be Ready).
VECTOR_STORE=brute

# Optional override for the Atlas index name when VECTOR_STORE=atlas.
# ATLAS_VECTOR_INDEX_NAME=flashcard_card_vec

